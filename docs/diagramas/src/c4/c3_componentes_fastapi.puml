@startuml c3_componentes_fastapi
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

Container(web, "App Principal Django", "Requisita PDFs via HTTP POST.")
System_Ext(fpdf2Lib, "FPDF2 Library", "Biblioteca Python de geração de PDF.")

Container_Boundary(api, "Microserviço de Relatórios — FastAPI / Uvicorn") {
  Component(fastApiApp, "FastAPI App", "FastAPI — main.py", "Ponto de entrada. title='Ordo Finance API'.")
  Component(healthEndpoint, "Health Endpoint", "FastAPI Route", "GET /health — Retorna {status: ok, service: reports-api}.")
  Component(rootEndpoint, "Root Endpoint", "FastAPI Route", "GET / — Retorna status do serviço.")
  Component(relatorioEndpoint, "Relatório PDF Endpoint", "FastAPI Route", "POST /relatorio/pdf. Recebe RelatorioRequest via body JSON. Retorna bytes do PDF (application/pdf).")
  Component(pydanticSchemas, "Pydantic Schemas", "Pydantic BaseModel", "TransacaoItem: data, descricao, tipo, valor, categoria. RelatorioRequest: usuario, transacoes[].")
  Component(pdfGenerator, "PDF Generator", "FPDF2 — interno", "Gera PDF com cabeçalho, tabela de transações e totais de receitas/despesas/saldo.")
}

Rel(web, fastApiApp, "POST /relatorio/pdf", "HTTP REST (JSON)")
Rel(fastApiApp, healthEndpoint, "Roteia GET /health", "internal")
Rel(fastApiApp, rootEndpoint, "Roteia GET /", "internal")
Rel(fastApiApp, relatorioEndpoint, "Roteia POST /relatorio/pdf", "internal")
Rel(relatorioEndpoint, pydanticSchemas, "Valida payload Pydantic", "internal")
Rel(relatorioEndpoint, pdfGenerator, "Gera PDF", "internal")
Rel(pdfGenerator, fpdf2Lib, "Usa biblioteca para gerar bytes", "Python import")

LAYOUT_WITH_LEGEND()
@enduml
