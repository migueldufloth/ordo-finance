@startuml c2_containers
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

Person(usuarioFinal, "Usuário", "Acessa a interface web pelo navegador.")
System_Ext(sentry, "Sentry", "Rastreamento de erros em produção.")
System_Ext(betterStack, "Better Stack", "Monitoramento externo de uptime.")

System_Boundary(ordoFinance, "Ordo Finance — Oracle Cloud Always Free VM") {
  Container(web, "App Principal", "Django 5 / Gunicorn / WhiteNoise", "Monolito SSR. Gerencia autenticação, transações, cartões, categorias, orçamentos, recorrentes e faturas. Gera PDF internamente via fpdf2. Expõe porta 8000.")
  Container(api, "Microserviço de Relatórios", "FastAPI / Uvicorn / FPDF2", "Serviço legado de geração de PDFs. Expõe porta 8001. Não utilizado pelo App Principal — geração de PDF foi movida para fpdf2 inline.")
  ContainerDb(db, "Banco de Dados", "PostgreSQL 15", "Armazena usuários, transações, categorias, cartões, orçamentos, faturas e recorrentes. Volume persistente.")
}

Rel(usuarioFinal, web, "Navega e interage", "HTTPS / HTML+CSS+JS")
Rel(web, db, "Lê e persiste dados", "SQL via Django ORM / psycopg2")
Rel(web, sentry, "Envia exceções", "HTTPS / SDK sentry-sdk")
Rel(betterStack, web, "Verifica uptime", "HTTP GET /health/")

LAYOUT_WITH_LEGEND()
@enduml
