@startuml c3_componentes_django
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

Person(usuarioFinal, "Usuário", "Acessa a interface web.")
ContainerDb(db, "PostgreSQL 15", "Banco de dados relacional.")
System_Ext(sentry, "Sentry", "Rastreamento de erros em produção.")

Container_Boundary(web, "App Principal — Django 5 / Gunicorn") {
  Component(urlRouter, "URL Router", "Django URLconf", "ordo_project/urls.py + financas/urls.py. 24 rotas registradas.")
  Component(authMiddleware, "Auth Middleware", "django.contrib.auth", "Middleware de sessão. @login_required / LoginRequiredMixin. Redireciona para /accounts/login/ se não autenticado.")
  Component(dashboardView, "Dashboard View", "FBV — views.py", "GET /. Seletor de período. Saldo, receitas/despesas do período, gráficos Chart.js, orçamentos e uso de limite dos cartões.")
  Component(transacaoViews, "Transação Views", "FBV — views.py", "Lista com filtros e paginação. Adicionar / Editar / Remover. Exportar CSV. Geração de PDF delegada ao serviço FastAPI (api) via HTTP POST.")
  Component(cartaoViews, "Cartão Views", "CBV — views.py", "BaseCartaoCreditoView (mixin). List / Create / Update / Delete. Exibe gasto do mês e percentual do limite.")
  Component(categoriaViews, "Categoria Views", "CBV — views.py", "BaseCategoriaView (mixin). List / Create / Update / Delete.")
  Component(orcamentoViews, "Orçamento Views", "CBV — views.py", "BaseOrcamentoView (mixin). List / Create / Update / Delete. Exibe gasto vs. limite mensal por categoria.")
  Component(recorrenteViews, "Recorrente Views", "CBV — views.py", "BaseTransacaoRecorrenteView (mixin). List / Create / Update / Delete.")
  Component(faturaViews, "Fatura Views", "FBV — views.py", "fatura_cartao: exibe transações do cartão por mês. marcar_fatura_paga: alterna status de pagamento.")
  Component(healthView, "Health View", "FBV — ordo_project/views.py", "GET /health/. Verifica banco. Retorna JSON HTTP 200 ou 503.")
  Component(forms, "Formulários", "Django ModelForms — forms.py", "TransacaoForm / CartaoCreditoForm / CategoriaForm / OrcamentoForm / TransacaoRecorrenteForm. Querysets filtrados por usuário.")
  Component(models, "Modelos ORM", "Django ORM — models.py", "Categoria / CartaoCredito / Transacao / Orcamento / FaturaCartao / TransacaoRecorrente. Todos com FK para User.")
  Component(templates, "Templates HTML", "Django Templates", "TailwindCSS CDN v3 + Alpine.js v3 + Chart.js v4 + Lucide Icons. base.html + 14 templates de feature + includes reutilizáveis.")
  Component(staticFiles, "Arquivos Estáticos", "WhiteNoise + Brotli", "Serve CSS, JS e imagens comprimidos com Brotli. CompressedManifestStaticFilesStorage.")
}

Rel(usuarioFinal, urlRouter, "Requisição HTTP", "HTTP/HTTPS")
Rel(urlRouter, authMiddleware, "Verifica sessão", "internal")
Rel(authMiddleware, dashboardView, "GET /", "internal")
Rel(authMiddleware, transacaoViews, "GET/POST /transacoes/*", "internal")
Rel(authMiddleware, cartaoViews, "GET/POST /transacoes/cartoes/*", "internal")
Rel(authMiddleware, categoriaViews, "GET/POST /transacoes/categorias/*", "internal")
Rel(authMiddleware, orcamentoViews, "GET/POST /transacoes/orcamentos/*", "internal")
Rel(authMiddleware, recorrenteViews, "GET/POST /transacoes/recorrentes/*", "internal")
Rel(authMiddleware, faturaViews, "GET/POST /transacoes/cartoes/<pk>/fatura/*", "internal")
Rel(urlRouter, healthView, "GET /health/", "internal")
Rel(transacaoViews, forms, "Valida dados POST", "internal")
Rel(cartaoViews, forms, "Valida dados POST", "internal")
Rel(categoriaViews, forms, "Valida dados POST", "internal")
Rel(orcamentoViews, forms, "Valida dados POST", "internal")
Rel(recorrenteViews, forms, "Valida dados POST", "internal")
Rel(dashboardView, models, "Consulta via ORM", "Django ORM")
Rel(transacaoViews, models, "CRUD", "Django ORM")
Rel(cartaoViews, models, "CRUD", "Django ORM")
Rel(categoriaViews, models, "CRUD", "Django ORM")
Rel(orcamentoViews, models, "CRUD", "Django ORM")
Rel(recorrenteViews, models, "CRUD", "Django ORM")
Rel(faturaViews, models, "Lê / atualiza", "Django ORM")
Rel(forms, models, "Cria/atualiza entidades", "Django ORM")
Rel(dashboardView, templates, "Renderiza HTML", "internal")
Rel(transacaoViews, templates, "Renderiza HTML", "internal")
Rel(cartaoViews, templates, "Renderiza HTML", "internal")
Rel(categoriaViews, templates, "Renderiza HTML", "internal")
Rel(orcamentoViews, templates, "Renderiza HTML", "internal")
Rel(recorrenteViews, templates, "Renderiza HTML", "internal")
Rel(faturaViews, templates, "Renderiza HTML", "internal")
Rel(staticFiles, usuarioFinal, "Entrega assets", "HTTP / Brotli")
Rel(models, db, "Lê e grava", "SQL / psycopg2")
Rel_Back(sentry, web, "Recebe exceções", "HTTPS / sentry-sdk")

LAYOUT_WITH_LEGEND()
@enduml
